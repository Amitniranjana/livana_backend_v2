      "matched_user_image": "https://storage.example.com/profiles/priya.jpg",
      "matched_at": "2026-03-07T19:30:00Z"
    },
    {
      "match_id": "f6a7b8c9-2d3e-4f5a-0b1c-2d3e4f5a6b7c",
      "matched_user_id": "a1b2c3d4-5e6f-7a8b-9c0d-1e2f3a4b5c6d",
