{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            c.id, c.name, c.description, c.created_by, c.created_at,\n            EXISTS(\n                SELECT 1 FROM community_members cm \n                WHERE cm.community_id = c.id AND cm.user_id = $1\n            ) as \"is_joined!\"\n        FROM communities c\n        ORDER BY c.created_at DESC\n        ",
